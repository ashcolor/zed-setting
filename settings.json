// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git_panel": {
    "tree_view": true
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "toolbar": {
    "agent_review": true
  },
  "debugger": {
    "button": false
  },
  "scrollbar": {
    "diagnostics": "all"
  },
  "diagnostics": {
    "button": false,
    "lsp_pull_diagnostics": {
      "enabled": true
    }
  },
  "enable_language_server": true,
  "agent": {
    "button": false,
    "favorite_models": [],
    "model_parameters": []
  },
  "collaboration_panel": {
    "button": false
  },
  "title_bar": {
    "show_menus": true,
    "show_onboarding_banner": false,
    "show_branch_icon": true
  },
  "status_bar": {
    "cursor_position_button": false,
    "active_language_button": true
  },
  "unnecessary_code_fade": 0.3,
  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 20.0,
  "ui_font_weight": 400.0,
  "buffer_line_height": "standard",
  "buffer_font_weight": 500.0,
  "icon_theme": "Material Icon Theme",
  "session": {
    "trust_all_worktrees": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "project_panel": {
    "auto_fold_dirs": false,
  },
  "minimap": {
    "show": "never",
  },
  "autosave": "on_focus_change",
  "buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New", "monospace"],
  "buffer_font_family": "BIZ UDゴシック",
  "file_types": {
    "markdown": ["*.md"],
  },
  "colorize_brackets": true,
  "auto_indent_on_paste": true,
  "use_on_type_format": true,
  "show_whitespaces": "all",
  "ensure_final_newline_on_save": true,
  "soft_wrap": "none",
  "tab_size": 2,
  "base_keymap": "VSCode",
  "ui_font_size": 18.0,
  "buffer_font_size": 14.0,
  "theme": "One Light",
  // ユーザ設定
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
  },
  "terminal": {
    "shell": {
      "program": "C:\\Program Files\\Git\\bin\\bash.exe",
    },
  },
  "restore_on_startup": "launchpad",
  "format_on_save": "on",
  "formatter": {
    "external": {
      "command": "pnpm",
      "arguments": ["exec", "oxfmt", "--stdin-filepath", "{buffer_path}"],
    },
  },
}
